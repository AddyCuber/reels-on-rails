# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
PEXELS_API_KEY=your_pexels_key_here        # Free at pexels.com/api

# ── YouTube Shorts ─────────────────────────────────────────────────────────────
# 1. Go to console.cloud.google.com
# 2. Create project → Enable YouTube Data API v3
# 3. Create OAuth 2.0 credentials → Download as client_secrets.json
YOUTUBE_CLIENT_SECRETS=client_secrets.json

# ── Instagram Reels ────────────────────────────────────────────────────────────
# 1. Need a Business or Creator Instagram account
# 2. Connect to a Facebook Page
# 3. Go to developers.facebook.com → Create app → Add Instagram Graph API
# 4. Generate a long-lived access token
INSTAGRAM_ACCESS_TOKEN=your_instagram_token_here
INSTAGRAM_USER_ID=your_instagram_user_id_here
